{
  "displayName": "Redis - High Memory Usage",
  "conditions": [
    {
      "displayName": "Memory usage > 80%",
      "conditionThreshold": {
        "filter": "resource.type=\"gce_instance\" resource.labels.instance_id=\"hr-360-redis\" metric.type=\"redis.googleapis.com/stats/memory/usage\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 858993459,
        "duration": "300s",
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_MEAN"
          }
        ]
      }
    }
  ],
  "combiner": "OR",
  "notificationChannels": [],
  "alertStrategy": {
    "autoClose": "1800s"
  }
}
