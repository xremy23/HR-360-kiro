{
  "name": "emergency-app-backend",
  "version": "1.0.0",
  "description": "Emergency Management App Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:performance": "jest --testNamePattern=\"Performance\"",
    "lint": "eslint src --ext .ts",
    "migrate": "ts-node src/migrations/migrate.ts",
    "migrate:run": "ts-node src/migrations/migrate.ts run",
    "migrate:status": "ts-node src/migrations/migrate.ts status",
    "migrate:create": "ts-node src/migrations/migrate.ts create"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "expo-server-sdk": "^3.7.0",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.0",
    "redis": "^4.7.1",
    "socket.io": "^4.7.0",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.19.41",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.20.0",
    "@types/redis": "^4.0.11",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.0"
  }
}
