{
  "displayName": "Cloud SQL - High CPU Usage",
  "conditions": [
    {
      "displayName": "CPU usage > 80%",
      "conditionThreshold": {
        "filter": "resource.type=\"cloudsql_database\" resource.labels.database_id=\"hr-360-497706:hr-360-postgres\" metric.type=\"cloudsql.googleapis.com/database/cpu/utilization\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 0.8,
        "duration": "300s",
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_MEAN"
          }
        ]
      }
    }
  ],
  "combiner": "OR",
  "notificationChannels": [],
  "alertStrategy": {
    "autoClose": "1800s"
  }
}
